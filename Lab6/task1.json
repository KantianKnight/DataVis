        }
      ],
      "transform": [
        {
          "type": "formula",
          "expr": "datum.category + ': ' + datum.proportion",
          "as": "tooltip"
        },
        {
          "type": "pie",
          "field": "proportion",
          "startAngle": 0,
          "endAngle": 6.29,
          "sort": false
        },
        {
          "type": "formula",
          "expr": "(datum.startAngle + datum.endAngle) / 2",
          "as": "midAngle"
        },
        {
          "type": "formula",
          "expr": "datum.midAngle - 1.5707963",
          "as": "drawAngle"
        },
        {
          "type": "formula",
          "expr": "width / 2 + (width / 2 + 2) * cos(datum.drawAngle)",
          "as": "x0"
        },
        {
          "type": "formula",
          "expr": "height / 2 + (width / 2 + 2) * sin(datum.drawAngle)",
          "as": "y0"
        },
        {
          "type": "formula",
          "expr": "width / 2 + (width / 2 + 45) * cos(datum.drawAngle)",
          "as": "x1"
        },
        {
          "type": "formula",
          "expr": "height / 2 + (width / 2 + 45) * sin(datum.drawAngle) + datum.dy",
          "as": "y1"
        },
        {
          "type": "formula",
          "expr": "datum.x0 + (datum.x1 - datum.x0) * 0.6",
          "as": "cx"
        },
        {"type": "formula", "expr": "datum.y0", "as": "cy"},
        {
          "type": "formula",
          "expr": "atan2(datum.y1 - datum.cy, datum.x1 - datum.cx) * 180 / PI + 90",
          "as": "arrowAngle"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": [
        "Manual slide refinement",
        "Selection-based slide refinement",
        "Selection-based slide initiation",
        "Outline-based slide refinement",
        "Outline-based slide initiation",
        "Other"
      ],
      "range": [
        "#F4C07A",
        "#C5DFA0",
        "#2CA25F",
        "#AED6EA",
        "#1F77B4",
        "#C9B8D8"
      ]
    }
  ],
  "marks": [
    {
      "type": "arc",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "fill": {"scale": "color", "field": "category"},
          "x": {"signal": "width / 2"},
          "y": {"signal": "height / 2"},
          "startAngle": {"field": "startAngle"},
          "endAngle": {"field": "endAngle"},
          "innerRadius": {"value": 0},
          "outerRadius": {"signal": "width / 2"},
          "cornerRadius": {"value": 0},
          "tooltip": {"field": "tooltip"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {
            "signal": "width / 2 + (width / 2 - 50) * cos(datum.drawAngle)"
          },
          "y": {
            "signal": "height / 2 + (width / 2 - 50) * sin(datum.drawAngle)"
          },
          "text": {"signal": "datum.proportion + '%'"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fontSize": {"value": 13},
          "fontWeight": {"value": "normal"},
          "fill": {"value": "#222222"}
        }
      }
    },
    {
      "type": "path",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "path": {
            "signal": "'M' + datum.x0 + ',' + datum.y0 + ' Q' + datum.cx + ',' + datum.cy + ' ' + datum.x1 + ',' + datum.y1"
          },
          "stroke": {"value": "#111"},
          "strokeWidth": {"value": 1.5},
          "fill": {"value": "transparent"}
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {"field": "x1"},
          "y": {"field": "y1"},
          "shape": {"value": "arrow"},
          "size": {"value": 180},
          "fill": {"value": "#111"},
          "angle": {"field": "arrowAngle"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {"signal": "datum.x1 + (cos(datum.drawAngle) >= 0 ? 12 : -12)"},
          "y": {"field": "y1"},
          "text": {"field": "labelLines"},
          "align": {"signal": "cos(datum.drawAngle) >= 0 ? 'left' : 'right'"},
          "baseline": {"value": "middle"},
          "fontSize": {"value": 14},
          "fontWeight": {"value": "bold"},
          "lineHeight": {"value": 18},
          "fill": {"value": "#000000"}
        }
      }
    }
  ],
  "config": {}
}