                <x-coord cell-offset='0.731429'>
                  <node-reference />
                </x-coord>
                <y-coord cell-offset='0.195714'>
                  <node-reference />
                </y-coord>
                <page-reference />
              </visual-coordinate>
            </bottom-right>
            <text x='0.5' y='0.5' />
          </annotation>
        </annotations>
      </table>
