  <dashboards>
    <dashboard name='Crash Analysis Story' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Crash Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='964' maxwidth='1016' minheight='964' minwidth='1016' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='3423' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='4253' />
            <zone h='84440' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='14730'>
              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='What airlines and phases of flights are responsible for the majority of crashes?&#10;&#10;We see that &#10;1) Asiana should be careful about their approaches&#10;2) Atlantic Southeast should be careful about their climbs' captured-sheet='Airlines Resulting in Most Crashes' id='1' />
                  <story-point caption='But frequency of crashes doesn&apos;t provide the full picture. We also care about fatalities. Here we see that American Airlines and United Airlines are actually responsible for most fatalities, which makes sense because they are massive airlines.&#10;&#10;It would be interesting to examine the probability of crashes per airlines, but we unfortunately don&apos;t have access to this data at the moment.' captured-sheet='Makes &amp; Flight Phases in Crashes' id='2'>
                    <capturedDeltas>
                      <worksheet name='Makes &amp; Flight Phases in Crashes'>
                        <annotations>
                          <annotation class='area' delta-type='edited' id='0' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                            <formatted-text>
                              <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>But frequency of crashes doesn&apos;t provide the full picture. We also care about fatalities. Here we see that American Airlines and United Airlines are actually responsible for most fatalities, which makes sense because they are massive airlines.</run>
                              <run fontalignment='0'>Æ&#10;&#10;</run>
                              <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>It would be interesting to examine the probability of crashes per airlines, but we unfortunately don&apos;t have access to this data at the moment.</run>
                            </formatted-text>
                            <top-left>
                              <visual-coordinate class='axis'>
                                <x-coord cell-offset='0.0885922'>
                                  <node-reference />
                                </x-coord>
                                <y-coord cell-offset='0.192534'>
                                  <node-reference />
                                </y-coord>
                                <page-reference />
                              </visual-coordinate>
                            </top-left>
                            <bottom-right>
                              <visual-coordinate class='axis'>
                                <x-coord cell-offset='0.550971'>
                                  <node-reference />
                                </x-coord>
                                <y-coord cell-offset='0.51277'>
                                  <node-reference />
                                </y-coord>
                                <page-reference />
                              </visual-coordinate>
                            </bottom-right>
                            <text x='0.5' y='0.5' />
                          </annotation>
                        </annotations>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='We can better visualize the frequency of crashes with a map. We can see that crashes in this dataset are most frequently located in the US.' captured-sheet='Global Heatmap of Crashes I' id='3'>
                    <capturedDeltas>
                      <worksheet name='Global Heatmap of Crashes I'>
                        <annotations>
                          <annotation class='area' delta-type='edited' id='0' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                            <formatted-text>
                              <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>We can better visualize the frequency of crashes with a map. We can see that crashes in this dataset are most frequently located in the US.</run>
                            </formatted-text>
                            <top-left>
                              <visual-coordinate class='axis'>
                                <x-coord axis-value='19471428.029250111'>
